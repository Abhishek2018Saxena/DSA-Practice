/*
============================================================
Problem: Queries On a Permutation With Key
Category: Binary Indexed Tree (Fenwick Tree) / Simulation
Platform: LeetCode
Language: C++

Problem Statement:
Given a permutation P = [1,2,3,...,m].

You are given an array queries, where queries[i] represents
a number to be searched in the permutation.

For each query:
1. Find the position of the element in the permutation.
2. Move that element to the front of the permutation.
3. Return the position before moving.

Example:
Input:
queries = [3,1,2,1]
m = 5

Output:
[2,1,2,1]

Explanation:
Initial permutation: [1,2,3,4,5]

Query 3 → position 2 → move to front
Permutation becomes [3,1,2,4,5]

Query 1 → position 1 → move to front
Permutation becomes [1,3,2,4,5]

and so on.

Approach:
1. Use Binary Indexed Tree (Fenwick Tree) to track positions.
2. Store current positions of numbers using an array.
3. Initially place numbers after index n (queries size).
4. When a number is queried:
      - Find how many numbers exist before it using BIT.
      - Remove it from its current position.
      - Move it to the front.
5. Update BIT accordingly.

Time Complexity:
    O((n + m) log(n + m))

Space Complexity:
    O(n + m)

============================================================
*/

#include <vector>
using namespace std;

class Solution {
public:
    vector<int> bit;
    int size;

    void update(int i, int val){
        while(i <= size){
            bit[i] += val;
            i += i & (-i);
        }
    }

    int query(int i){
        int sum = 0;
        while(i > 0){
            sum += bit[i];
            i -= i & (-i);
        }
        return sum;
    }

    vector<int> processQueries(vector<int>& queries, int m) {

        int n = queries.size();
        size = n + m + 2;

        bit.assign(size + 1,0);

        vector<int> pos(m + 1);

        for(int i = 1; i <= m; i++){
            pos[i] = n + i;
            update(pos[i],1);
        }

        vector<int> ans;
        int front = n;

        for(int q : queries){

            int p = pos[q];

            ans.push_back(query(p) - 1);

            update(p,-1);

            pos[q] = front;
            update(front,1);

            front--;
        }

        return ans;
    }
};
