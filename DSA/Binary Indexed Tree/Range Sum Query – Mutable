/*
============================================================
Problem: Range Sum Query – Mutable
Category: Binary Indexed Tree (Fenwick Tree)
Platform: LeetCode
Language: C++

Approach:
    - Use a Binary Indexed Tree (Fenwick Tree).
    - BIT supports efficient prefix sums and updates.

    Key Operations:
    1. add(index, val)
         → update BIT by adding val at index.
    2. prefixSum(index)
         → compute sum from index 1 to index.
    3. update(index, val)
         → update value in array and adjust BIT.
    4. sumRange(left, right)
         → prefixSum(right+1) - prefixSum(left)

Time Complexity:
    update()   -> O(log n)
    sumRange() -> O(log n)

Space Complexity:
    O(n)

============================================================

Example:
Input:
    nums = [1,3,5]

Operations:
    sumRange(0,2) → 9
    update(1,2)
    sumRange(0,2) → 8

============================================================
*/

#include <vector>
using namespace std;

class NumArray {
public:
    vector<int> bit;
    vector<int> nums;
    int n;

    NumArray(vector<int>& nums) {
        n = nums.size();
        this->nums = nums;
        bit.resize(n + 1, 0);

        // Build BIT
        for (int i = 0; i < n; i++) {
            add(i + 1, nums[i]);
        }
    }

    // Update BIT
    void add(int index, int val) {
        while (index <= n) {
            bit[index] += val;
            index += index & (-index);
        }
    }

    // Get prefix sum
    int prefixSum(int index) {
        int sum = 0;
        while (index > 0) {
            sum += bit[index];
            index -= index & (-index);
        }
        return sum;
    }

    void update(int index, int val) {
        int diff = val - nums[index];
        nums[index] = val;
        add(index + 1, diff);
    }

    int sumRange(int left, int right) {
        return prefixSum(right + 1) - prefixSum(left);
    }
};
