/*
============================================================
Problem: Next Greater Element I
Category: Stack / Monotonic Stack
Platform: LeetCode
Language: C++

Approach:
    - Use a monotonic decreasing stack
    - Traverse nums2 and map each element to its next greater
    - For nums1, directly fetch from map
    - Remaining stack elements have no next greater → -1

Time Complexity:
    O(N + M)

Space Complexity:
    O(N)

============================================================

Example:
Input:
    nums1 = [4,1,2]
    nums2 = [1,3,4,2]

Output:
    [-1,3,-1]

Explanation:
    Next greater of:
        4 → -1
        1 → 3
        2 → -1
============================================================
*/

#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    vector<int> nextGreaterElement(vector<int>& nums1, vector<int>& nums2) {
        
        unordered_map<int, int> mp;  // value -> next greater
        stack<int> st;
        
        // Process nums2
        for (int num : nums2) {
            
            while (!st.empty() && st.top() < num) {
                mp[st.top()] = num;
                st.pop();
            }
            
            st.push(num);
        }
        
        // Remaining elements have no next greater
        while (!st.empty()) {
            mp[st.top()] = -1;
            st.pop();
        }
        
        // Build result for nums1
        vector<int> ans;
        
        for (int num : nums1) {
            ans.push_back(mp[num]);
        }
        
        return ans;
    }
};
