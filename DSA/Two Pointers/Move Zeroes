/*
============================================================
Problem: Move Zeroes
Category: Two Pointers / Array
Platform: LeetCode
Language: C++

Approach:
    - Use two pointers:
          i → position to place next non-zero element
          j → scans the array
    - If nums[j] != 0:
          → swap nums[i] and nums[j]
          → move i forward
    - This keeps all non-zero elements in order
      and moves zeros to the end.

Time Complexity:
    O(n)

Space Complexity:
    O(1)

============================================================

Example:
Input:
    nums = [0,1,0,3,12]

Output:
    [1,3,12,0,0]

============================================================
*/

#include <vector>
using namespace std;

class Solution {
public:
    void moveZeroes(vector<int>& nums) {
        
        int i = 0;
        
        for (int j = 0; j < nums.size(); j++)
        {
            if (nums[j] != 0)
            {
                swap(nums[i], nums[j]);
                i++;
            }
        }
    }
};
