/*
============================================================
Problem: Remove Duplicates from Sorted Array
Category: Two Pointers / Array
Platform: LeetCode
Language: C++

Approach:
    - Use two pointers:
          i → position of last unique element
          j → scans the array
    - If nums[j] != nums[i]:
          → move i forward
          → copy nums[j] to nums[i]
    - At the end, first (i + 1) elements are unique.

Time Complexity:
    O(n)

Space Complexity:
    O(1)

============================================================

Example:
Input:
    nums = [1,1,2]

Output:
    2

Modified Array:
    [1,2,_]

============================================================
*/

#include <vector>
using namespace std;

class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        
        int i = 0;
        
        for (int j = 1; j < nums.size(); j++)
        {
            if (nums[j] != nums[i])
            {
                i++;
                nums[i] = nums[j];
            }
        }
        
        return i + 1;
    }
};
