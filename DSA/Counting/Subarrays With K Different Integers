/*
============================================================
Problem: Subarrays with K different integers
Category: Sliding Window / Hashing / Prefix Counting
Platform: LeetCode
Language: C++

Problem Statement:
Given an integer array nums and an integer k,
return the number of good subarrays of nums.

A good subarray is one that contains exactly k distinct integers.

Example:
Input:
nums = [1,2,1,2,3]
k = 2

Output:
7

Optimal Idea:
Exactly K distinct =
    atMost(K) − atMost(K − 1)

Approach:
1. Create helper function atMostK():
      - Use Sliding Window
      - Maintain frequency map
      - Expand right pointer
      - Shrink left pointer when distinct > k
2. Count all valid subarrays ending at each index.
3. Final answer:
      atMost(k) − atMost(k−1)

Why this works?
Because:
All subarrays with exactly K distinct =
    all with ≤K − all with ≤(K−1)

Time Complexity:
    O(n)

Space Complexity:
    O(k)

Important Pattern:
⭐ Very powerful Sliding Window Trick
⭐ Used in many Exact K problems

============================================================
*/

#include <vector>
#include <unordered_map>
using namespace std;

class Solution {
public:

    int atMostK(vector<int>& nums, int k) {
        unordered_map<int,int> freq;
        int left = 0;
        int count = 0;

        for(int right = 0; right < nums.size(); right++) {

            if(freq[nums[right]] == 0)
                k--;

            freq[nums[right]]++;

            while(k < 0) {
                freq[nums[left]]--;

                if(freq[nums[left]] == 0)
                    k++;

                left++;
            }

            count += right - left + 1;
        }

        return count;
    }

    int subarraysWithKDistinct(vector<int>& nums, int k) {
        return atMostK(nums, k) - atMostK(nums, k-1);
    }
};
