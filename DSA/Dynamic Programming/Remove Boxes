/*
============================================================
Problem: Remove Boxes
Category: Dynamic Programming / Interval DP / Memoization
Platform: LeetCode (Hard)
Language: C++

Problem Statement:
You are given several boxes with different colors
represented by numbers.

You can remove boxes in groups of the same color.

If you remove k same-colored boxes together,
you get k * k points.

Return the maximum points you can get.

Example:
Input:
boxes = [1,3,2,2,2,3,4,3,1]

Output:
23

Core Idea:
This is an Interval DP problem.

State Definition:
dp[l][r][k] =
maximum points for subarray [l…r]
with k extra boxes of same color as boxes[r]
attached to the right.

Important Trick:
Sometimes it is better NOT to remove boxes immediately,
but merge them later to gain more score.

Transition:
1. Remove boxes[r] with k extra same color
2. Try merging with previous same colored box

Time Complexity:
    O(n^4) worst case

Space Complexity:
    O(n^3)

Why Important?
⭐ One of the hardest DP patterns  
⭐ Combines:
    - Interval DP
    - Memoization
    - State Compression Thinking
⭐ Improves DP intuition strongly

============================================================
*/

#include <vector>
#include <cstring>
using namespace std;

class Solution {
public:

    int dp[100][100][100];

    int solve(vector<int>& boxes, int l, int r, int k){
        if(l > r) return 0;

        if(dp[l][r][k] != 0)
            return dp[l][r][k];

        int res = solve(boxes, l, r-1, 0) + (k+1)*(k+1);

        for(int i = l; i < r; i++){
            if(boxes[i] == boxes[r]){
                res = max(res,
                          solve(boxes, l, i, k+1) +
                          solve(boxes, i+1, r-1, 0));
            }
        }

        return dp[l][r][k] = res;
    }

    int removeBoxes(vector<int>& boxes) {
        memset(dp, 0, sizeof(dp));
        return solve(boxes, 0, boxes.size()-1, 0);
    }
};
