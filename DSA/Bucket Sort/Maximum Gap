/*
============================================================
Problem: Maximum Gap
Category: Sorting / Bucket Sort / Pigeonhole Principle
Platform: LeetCode
Language: C++

Problem Statement:
Given an integer array nums,
return the maximum difference between successive elements
in its sorted form.

If the array contains less than 2 elements → return 0.

Example:
Input:
nums = [3,6,9,1]

Output:
3

Explanation:
Sorted array → [1,3,6,9]
Gaps → 2,3,3
Maximum gap = 3

Optimal Idea:
Instead of fully sorting (O(n log n)),
we use Bucket Sort based on Pigeonhole Principle.

Key Observation:
Maximum gap will NOT be inside a bucket,
it will always be between buckets.

Approach:
1. Find minimum and maximum element.
2. Compute bucket size:
       bucketSize = max(1, (max - min)/(n-1))
3. Place each number into its bucket.
4. Track bucket min and bucket max.
5. Traverse buckets and compute gap between:
       current bucket min − previous bucket max.

Time Complexity:
    O(n)

Space Complexity:
    O(n)

Why Important?
⭐ Linear time sorting concept  
⭐ Pigeonhole principle usage  
⭐ Asked in high-level interviews  

============================================================
*/

#include <vector>
#include <algorithm>
#include <climits>
using namespace std;

class Solution {
public:
    int maximumGap(vector<int>& nums) {
        int n = nums.size();
        if (n < 2) return 0;

        int mn = *min_element(nums.begin(), nums.end());
        int mx = *max_element(nums.begin(), nums.end());

        if (mn == mx) return 0;

        int bucketSize = max(1, (mx - mn) / (n - 1));
        int bucketCount = (mx - mn) / bucketSize + 1;

        vector<int> bucketMin(bucketCount, INT_MAX);
        vector<int> bucketMax(bucketCount, INT_MIN);
        vector<bool> used(bucketCount, false);

        // Fill buckets
        for (int num : nums) {
            int idx = (num - mn) / bucketSize;
            bucketMin[idx] = min(bucketMin[idx], num);
            bucketMax[idx] = max(bucketMax[idx], num);
            used[idx] = true;
        }

        // Compute maximum gap
        int prevMax = mn;
        int maxGap = 0;

        for (int i = 0; i < bucketCount; i++) {
            if (!used[i]) continue;

            maxGap = max(maxGap, bucketMin[i] - prevMax);
            prevMax = bucketMax[i];
        }

        return maxGap;
    }
};
