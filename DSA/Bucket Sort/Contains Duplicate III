/*
============================================================
Problem: Contains Duplicate III
Category: Sliding Window / Hashing / Bucket Sort Concept
Platform: LeetCode
Language: C++

Problem Statement:
Given an integer array nums and two integers indexDiff and valueDiff, 
return true if there exist two indices i and j such that: 

1. |i − j| ≤ indexDiff 
2. |nums[i] − nums[j]| ≤ valueDiff 
 
Otherwise return false.

Example: 
Input: 
nums = [1,2,3,1], indexDiff = 3, valueDiff = 0
 
Output:
true

Optimal Idea:
Use Bucket Hashing + Sliding Window.

Key Concept:
Numbers within valueDiff must fall into:
    - Same bucket OR
    - Adjacent bucket

Bucket Size:
    valueDiff + 1

Approach:
1. Compute bucket ID for each number.
2. Check:
      - Same bucket → valid
      - Neighbor bucket → check difference
3. Maintain sliding window of size indexDiff.
4. Remove old elements from bucket.

Time Complexity:
    O(n)

Space Complexity:
    O(indexDiff)

Important Learning:
⭐ Combines:
    - Sliding Window
    - Hashing
    - Bucket Thinking
⭐ Very tricky interview problem

============================================================
*/

#include <vector>
#include <unordered_map>
#include <cmath>
using namespace std;

class Solution {
public:
    bool containsNearbyAlmostDuplicate(vector<int>& nums, int indexDiff, int valueDiff) {
        if (valueDiff < 0) return false;

        unordered_map<long long, long long> bucket;
        long long bucketSize = (long long)valueDiff + 1;

        for (int i = 0; i < nums.size(); i++) {
            long long num = nums[i];
            
            // Bucket ID
            long long id = num / bucketSize;
            if (num < 0) id--;

            // Same bucket
            if (bucket.count(id)) return true;

            // Left bucket
            if (bucket.count(id - 1) && abs(num - bucket[id - 1]) <= valueDiff)
                return true;

            // Right bucket
            if (bucket.count(id + 1) && abs(num - bucket[id + 1]) <= valueDiff)
                return true;

            bucket[id] = num;

            // Maintain window size
            if (i >= indexDiff) {
                long long old = nums[i - indexDiff];
                long long oldId = old / bucketSize;
                if (old < 0) oldId--;
                bucket.erase(oldId);
            }
        }

        return false;
    }
};
