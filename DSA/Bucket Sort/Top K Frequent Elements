/*
============================================================
Problem: Top K frequent elements
Category: Hashing / Bucket Sort / Heap Alternative
Platform: LeetCode
Language: C++

Problem Statement:
Given an integer array nums and an integer k,
return the k most frequent elements.

Example:
Input:
nums = [1,1,1,2,2,3]
k = 2

Output:
[1,2]

Optimal Idea:
Instead of sorting by frequency (O(n log n)),
we can use Bucket Sort because:
Maximum frequency of any element ≤ n.

Approach:
1. Count frequency using HashMap.
2. Create buckets:
       bucket[i] → stores numbers having frequency = i
3. Traverse buckets from highest frequency to lowest.
4. Collect first k elements.

Time Complexity:
    O(n)

Space Complexity:
    O(n)

Why Important?
⭐ Very popular interview problem  
⭐ Demonstrates frequency bucket thinking  
⭐ Alternative solution uses Min Heap (O(n log k))

============================================================
*/

#include <vector>
#include <unordered_map>
using namespace std;

class Solution {
public:
    vector<int> topKFrequent(vector<int>& nums, int k) {
        unordered_map<int, int> freq;
        
        // Step 1: Count frequency
        for (int num : nums) {
            freq[num]++;
        }

        int n = nums.size();
        
        // Step 2: Buckets (index = frequency)
        vector<vector<int>> buckets(n + 1);

        for (auto &p : freq) {
            int num = p.first;
            int f = p.second;
            buckets[f].push_back(num);
        }

        // Step 3: Collect top k frequent
        vector<int> result;
        
        for (int i = n; i >= 0 && result.size() < k; i--) {
            for (int num : buckets[i]) {
                result.push_back(num);
                if (result.size() == k) break;
            }
        }

        return result;
    }
};
