/*
============================================================
Problem: Evaluate Division
Category: Graph / BFS / Path Finding / Weighted Graph
Platform: LeetCode
Language: C++

Problem Statement:
You are given equations like:

a / b = 2.0
b / c = 3.0

You must answer queries like:
a / c = ?

Return the result for each query.
If answer cannot be determined → return -1.

Example:
Input:
equations = [["a","b"],["b","c"]]
values = [2.0,3.0]
queries = [["a","c"],["b","a"],["a","e"]]

Output:
[6.0,0.5,-1.0]

Core Idea:
Treat each variable as a graph node.

Equation:
a / b = k
means:
a → b weight = k  
b → a weight = 1/k  

Then problem becomes:
👉 Find path from start → end  
👉 Multiply weights along path.

Approach:
1. Build adjacency list graph.
2. For each query perform BFS:
      - Keep current multiplication value.
      - Stop when destination found.
3. If unreachable → return -1.

Time Complexity:
    O(Q * (V + E))

Space Complexity:
    O(V + E)

Why Important?
⭐ Classic graph modeling problem  
⭐ Shows how math equations become graph paths  
⭐ Can also be solved using Union Find  

============================================================
*/

#include <vector>
#include <unordered_map>
#include <unordered_set>
#include <queue>
#include <string>
using namespace std;

class Solution {
public:
    unordered_map<string, vector<pair<string, double>>> graph;

    double bfs(string start, string end) {
        if (graph.find(start) == graph.end() ||
            graph.find(end) == graph.end())
            return -1.0;

        queue<pair<string, double>> q;
        unordered_set<string> visited;

        q.push({start, 1.0});
        visited.insert(start);

        while (!q.empty()) {
            auto [node, value] = q.front();
            q.pop();

            if (node == end)
                return value;

            for (auto &nbr : graph[node]) {
                string next = nbr.first;
                double wt = nbr.second;

                if (!visited.count(next)) {
                    visited.insert(next);
                    q.push({next, value * wt});
                }
            }
        }

        return -1.0;
    }

    vector<double> calcEquation(
        vector<vector<string>>& equations,
        vector<double>& values,
        vector<vector<string>>& queries) {

        // Build graph
        for (int i = 0; i < equations.size(); i++) {
            string a = equations[i][0];
            string b = equations[i][1];
            double val = values[i];

            graph[a].push_back({b, val});
            graph[b].push_back({a, 1.0 / val});
        }

        vector<double> result;

        for (auto &q : queries) {
            string start = q[0];
            string end = q[1];

            if (start == end && graph.find(start) != graph.end())
                result.push_back(1.0);
            else
                result.push_back(bfs(start, end));
        }

        return result;
    }
};
