/*
============================================================
Problem: Sort List
Category: Linked List / Divide and Conquer / Merge Sort
Platform: LeetCode
Language: C++

Problem Statement:
Given the head of a linked list, return the list after sorting it
in ascending order.

Example:
Input:
head = [4,2,1,3]

Output:
[1,2,3,4]

Approach:
1. Use Merge Sort on Linked List.
2. Find middle using Slow and Fast pointer.
3. Split the list into two halves.
4. Recursively sort both halves.
5. Merge two sorted lists using merge function.

Why Merge Sort?
- Linked List does not allow random access.
- Merge Sort works efficiently with pointers.

Time Complexity:
    O(n log n)

Space Complexity:
    O(log n) (recursion stack)

============================================================
*/

#include <vector>
using namespace std;

/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */

class Solution {
public:

    ListNode* merge(ListNode* l1, ListNode* l2) {
        ListNode dummy(0);
        ListNode* tail = &dummy;

        while (l1 && l2) {
            if (l1->val < l2->val) {
                tail->next = l1;
                l1 = l1->next;
            } else {
                tail->next = l2;
                l2 = l2->next;
            }
            tail = tail->next;
        }

        if (l1) tail->next = l1;
        if (l2) tail->next = l2;

        return dummy.next;
    }

    ListNode* sortList(ListNode* head) {
        if (!head || !head->next) return head;

        ListNode* slow = head;
        ListNode* fast = head;
        ListNode* prev = nullptr;

        // Find middle
        while (fast && fast->next) {
            prev = slow;
            slow = slow->next;
            fast = fast->next->next;
        }

        prev->next = nullptr;   // split

        ListNode* l1 = sortList(head);
        ListNode* l2 = sortList(slow);

        return merge(l1, l2);
    }
};
