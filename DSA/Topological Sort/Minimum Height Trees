/*
============================================================
Problem: Minimum height trees
Category: Graph / Topological Sort / BFS / Tree Centers
Platform: LeetCode
Language: C++

Problem Statement:
You are given an undirected tree with n nodes.

Return all possible root nodes such that
the tree has minimum height.

Example:
n = 4
edges = [[1,0],[1,2],[1,3]]

Output:
[1]

Core Idea:
The root of Minimum Height Tree is always
the **center of the tree**.

To find center:
👉 Remove leaf nodes level by level
   (like topological sort)

Eventually:
1 or 2 nodes remain → these are answers

Approach:
1. Build graph (adj list + degree array)
2. Push all leaf nodes (degree == 1)
3. Remove leaves layer by layer
4. Stop when remaining nodes ≤ 2
5. Return remaining nodes

Time Complexity:
    O(V + E)

Space Complexity:
    O(V + E)

Why Important?
⭐ Variation of Topological Sort  
⭐ Used in tree center problems  
⭐ Very common interview question  

============================================================
*/

#include <vector>
#include <queue>
using namespace std;

class Solution {
public:
    vector<int> findMinHeightTrees(int n, vector<vector<int>>& edges) {

        if (n == 1) return {0};

        vector<vector<int>> adj(n);
        vector<int> degree(n, 0);

        // Build graph
        for (auto &e : edges) {
            int u = e[0], v = e[1];
            adj[u].push_back(v);
            adj[v].push_back(u);
            degree[u]++;
            degree[v]++;
        }

        queue<int> q;

        // Add all leaf nodes
        for (int i = 0; i < n; i++) {
            if (degree[i] == 1)
                q.push(i);
        }

        int remainingNodes = n;

        // Trim leaves
        while (remainingNodes > 2) {
            int size = q.size();
            remainingNodes -= size;

            while (size--) {
                int node = q.front();
                q.pop();

                for (int neighbor : adj[node]) {
                    degree[neighbor]--;
                    if (degree[neighbor] == 1)
                        q.push(neighbor);
                }
            }
        }

        // Remaining nodes = centers
        vector<int> result;
        while (!q.empty()) {
            result.push_back(q.front());
            q.pop();
        }

        return result;
    }
};
